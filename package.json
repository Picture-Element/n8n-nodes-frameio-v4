{
	"name": "n8n-nodes-frameio-v4",
	"version": "0.1.0",
	"description": "n8n community nodes for the Frame.io V4 API (Adobe) — projects, folders, files, uploads, comments, shares, version stacks and webhook triggers",
	"keywords": [
		"n8n-community-node-package",
		"frameio",
		"frame.io",
		"adobe",
		"video",
		"review",
		"media"
	],
	"license": "MIT",
	"homepage": "https://github.com/Picture-Element/n8n-nodes-frameio-v4",
	"author": {
		"name": "Ben Gosciniak",
		"email": "ben@picture-element.fr"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Picture-Element/n8n-nodes-frameio-v4.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"format": "prettier nodes credentials --write",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/FrameIoV4OAuth2Api.credentials.js",
			"dist/credentials/FrameIoV4ServerToServerApi.credentials.js",
			"dist/credentials/FrameIoV4LegacyTokenApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/FrameIoV4/FrameIoV4.node.js",
			"dist/nodes/FrameIoV4Trigger/FrameIoV4Trigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.39.3",
		"eslint": "^9.39.4",
		"prettier": "^3.8.3",
		"release-it": "^20.2.0",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
